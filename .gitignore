# ======================
# 拟态项目 - Electron 桌宠应用
# ======================

# --- 依赖 (Dependencies) ---
node_modules/

# --- 构建产物 (Build artifacts) ---
dist/
out/
release/
build/

# --- 日志 (Logs) ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- 操作系统文件 (OS files) ---
Thumbs.db
Desktop.ini
ehthumbs.db
.DS_Store
.AppleDouble
.LSOverride
Icon?

# --- 编辑器 / IDE 配置 ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- 环境变量 (Environment) ---
.env
.env.local
.env.development
.env.production
.env.test

# --- 临时文件 (Temp files) ---
*.tmp
*.temp
*.cache

# --- Electron 相关 ---
# 打包后的应用
*.asar
# Electron Builder 输出
electron-builder.yml

# --- 系统隐藏文件 ---
._*

# --- 其他 ---
# 覆盖率报告
coverage/
.nyc_output/

# 操作系统生成的文件夹
$RECYCLE.BIN/
System Volume Information/

# 缓存目录
.cache/
